local ESP = {
    Enabled = false,
    ShowBox = true,
    ShowName = true,
    ShowDistance = true,
    ShowHealth = true,
    BoxColor = Color3.fromRGB(255, 50, 50),
    TextColor = Color3.fromRGB(255, 255, 255),
    Objects = {}
}

local HitboxEnabled = false
local HitboxSize = 2.5
local HitboxTransparency = 0.7

-- ==================== ESP FUNCTIONS ====================
local function DestroyESP(player)
    if ESP.Objects[player] then
        for _, obj in pairs(ESP.Objects[player]) do
            if obj and obj.Remove then obj:Remove() end
        end
        ESP.Objects[player] = nil
    end
end

local function UpdateESP()
    if not ESP.Enabled then return end

    for _, player in pairs(game.Players:GetPlayers()) do
        if player == game.Players.LocalPlayer then continue end

        local character = player.Character
        if not character then 
            DestroyESP(player)
            continue 
        end

        local root = character:FindFirstChild("HumanoidRootPart")
        local head = character:FindFirstChild("Head")
        local humanoid = character:FindFirstChild("Humanoid")

        if not root or not head or not humanoid then 
            DestroyESP(player)
            continue 
        end

        local rootPos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(root.Position)
        if not onScreen then 
            DestroyESP(player)
            continue 
        end

        local headPos = workspace.CurrentCamera:WorldToViewportPoint(head.Position)
        local legPos = workspace.CurrentCamera:WorldToViewportPoint(root.Position - Vector3.new(0, 3.5, 0))

        local height = math.abs(headPos.Y - legPos.Y)
        local width = height * 0.65

        if not ESP.Objects[player] then ESP.Objects[player] = {} end

        -- Box
        if ESP.ShowBox then
            local box = ESP.Objects[player].Box or Drawing.new("Square")
            box.Thickness = 2
            box.Color = ESP.BoxColor
            box.Transparency = 1
            box.Filled = false
            box.Size = Vector2.new(width, height)
            box.Position = Vector2.new(rootPos.X - width/2, rootPos.Y - height/2)
            ESP.Objects[player].Box = box
        end

        -- Name
        if ESP.ShowName then
            local name = ESP.Objects[player].Name or Drawing.new("Text")
            name.Text = player.Name
            name.Size = 15
            name.Color = ESP.TextColor
            name.Outline = true
            name.Center = true
            name.Position = Vector2.new(rootPos.X, rootPos.Y - height/2 - 22)
            ESP.Objects[player].Name = name
        end

        -- Distance
        if ESP.ShowDistance then
            local distance = root and game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and
                (root.Position - game.Players.LocalPlayer.Character.HumanoidRootPart.Position).Magnitude or 0

            local dist = ESP.Objects[player].Dist or Drawing.new("Text")
            dist.Text = string.format("%.0f stud", distance)
            dist.Size = 14
            dist.Color = Color3.fromRGB(200, 200, 200)
            dist.Outline = true
            dist.Center = true
            dist.Position = Vector2.new(rootPos.X, rootPos.Y + height/2 + 6)
            ESP.Objects[player].Dist = dist
        end

        -- Health
        if ESP.ShowHealth and humanoid then
            local healthPercent = humanoid.Health / humanoid.MaxHealth
            local healthBar = ESP.Objects[player].Health or Drawing.new("Square")
            healthBar.Size = Vector2.new(5, height * healthPercent)
            healthBar.Position = Vector2.new(rootPos.X - width/2 - 10, rootPos.Y - height/2 + height * (1 - healthPercent))
            healthBar.Color = Color3.fromRGB(255 * (1 - healthPercent), 255 * healthPercent, 0)
            healthBar.Filled = true
            ESP.Objects[player].Health = healthBar
        end
    end
end

