-- Hitbox Loop
game:GetService("RunService").Heartbeat:Connect(function()
    if not HitboxEnabled then return end
    for _, player in pairs(game.Players:GetPlayers()) do
        if player ~= game.Players.LocalPlayer and player.Character and player.Character:FindFirstChild("Head") then
            local head = player.Character.Head
            head.Size = Vector3.new(HitboxSize, HitboxSize, HitboxSize)
            head.Transparency = HitboxTransparency
            head.CanCollide = false
        end
    end
end)

-- ==================== AIMLOCK (bez zmian) ====================
local AimlockEnabled = false
local AimlockFOV = 120
local AimlockSmooth = 8
local FOVCircle

local function CreateFOVCircle()
    if FOVCircle then FOVCircle:Remove() end
    FOVCircle = Drawing.new("Circle")
    FOVCircle.Thickness = 2
    FOVCircle.Color = Color3.fromRGB(255, 255, 255)
    FOVCircle.Transparency = 0.6
    FOVCircle.Filled = false
    FOVCircle.NumSides = 80
end

BloxStrikeTab:CreateSection("Aimlock")

BloxStrikeTab:CreateToggle({
    Name = "Aimlock na Głowę (Trzymaj PPM)",
    CurrentValue = false,
    Callback = function(Value)
        AimlockEnabled = Value
        if Value and not FOVCircle then CreateFOVCircle() end
        if not Value and FOVCircle then FOVCircle:Remove(); FOVCircle = nil end
    end
})

BloxStrikeTab:CreateSlider({
    Name = "Aimlock FOV",
    Range = {30, 500},
    Increment = 5,
    CurrentValue = 120,
    Callback = function(Value) AimlockFOV = Value end
})

BloxStrikeTab:CreateSlider({
    Name = "Smoothness",
    Range = {1, 25},
    Increment = 1,
    CurrentValue = 8,
    Callback = function(Value) AimlockSmooth = Value end
})

-- Aimlock + FOV Loop
game:GetService("RunService").RenderStepped:Connect(function()
    if FOVCircle then
        local mouseLoc = game:GetService("UserInputService"):GetMouseLocation()
        FOVCircle.Position = mouseLoc
        FOVCircle.Radius = AimlockFOV
        FOVCircle.Visible = AimlockEnabled
    end

    if not AimlockEnabled then return end

    local camera = workspace.CurrentCamera
    local mouse = game.Players.LocalPlayer:GetMouse()
    local closestDist = AimlockFOV
    local closestPlayer = nil

    for _, player in pairs(game.Players:GetPlayers()) do
        if player ~= game.Players.LocalPlayer and player.Character and player.Character:FindFirstChild("Head") then
            local headPos = camera:WorldToViewportPoint(player.Character.Head.Position)
            local mousePos = Vector2.new(mouse.X, mouse.Y)
            local dist = (Vector2.new(headPos.X, headPos.Y) - mousePos).Magnitude

            if dist < closestDist then
                closestDist = dist
                closestPlayer = player
            end
        end
    end

    if closestPlayer and closestPlayer.Character and closestPlayer.Character:FindFirstChild("Head") then
        local targetPos = closestPlayer.Character.Head.Position
        camera.CFrame = camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position, targetPos), 1 / AimlockSmooth)
    end
end)

-- Bind PPM
game:GetService("UserInputService").InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton2 then AimlockEnabled = true end
end)
game:GetService("UserInputService").InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton2 then AimlockEnabled = false end
end)

