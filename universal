-- ==================== HITBOX EXPANDER ====================
BloxStrikeTab:CreateSection("Head Hitbox Expander")

BloxStrikeTab:CreateToggle({
    Name = "Włącz Hitbox Expander",
    CurrentValue = false,
    Callback = function(Value)
        HitboxEnabled = Value
    end
})

BloxStrikeTab:CreateSlider({Name = "Rozmiar Hitboxu", Range = {1, 10}, Increment = 0.1, CurrentValue = 2.5, Callback = function(v) HitboxSize = v end})
BloxStrikeTab:CreateSlider({Name = "Przezroczystość", Range = {0, 1}, Increment = 0.05, CurrentValue = 0.7, Callback = function(v) HitboxTransparency = v end})

game:GetService("RunService").Heartbeat:Connect(function()
    if not HitboxEnabled then return end
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= game.Players.LocalPlayer and p.Character and p.Character:FindFirstChild("Head") then
            local h = p.Character.Head
            h.Size = Vector3.new(HitboxSize, HitboxSize, HitboxSize)
            h.Transparency = HitboxTransparency
            h.CanCollide = false
        end
    end
end)

-- ==================== AIMLOCK ====================
-- (pozostawiam bez zmian - działał wcześniej)
local function CreateFOV()
    if FOVCircle then FOVCircle:Remove() end
    FOVCircle = Drawing.new("Circle")
    FOVCircle.Thickness = 2
    FOVCircle.Color = Color3.fromRGB(255,255,255)
    FOVCircle.Transparency = 0.6
    FOVCircle.Filled = false
    FOVCircle.NumSides = 80
end

BloxStrikeTab:CreateSection("Aimlock")

BloxStrikeTab:CreateToggle({
    Name = "Aimlock na Głowę (Trzymaj PPM)",
    CurrentValue = false,
    Callback = function(v)
        AimlockEnabled = v
        if v and not FOVCircle then CreateFOV() end
        if not v and FOVCircle then FOVCircle:Remove(); FOVCircle = nil end
    end
})

BloxStrikeTab:CreateSlider({Name = "FOV", Range = {30, 500}, Increment = 5, CurrentValue = 120, Callback = function(v) AimlockFOV = v end})
BloxStrikeTab:CreateSlider({Name = "Smoothness", Range = {1, 25}, Increment = 1, CurrentValue = 8, Callback = function(v) AimlockSmooth = v end})

game:GetService("RunService").RenderStepped:Connect(function()
    if FOVCircle then
        local m = game:GetService("UserInputService"):GetMouseLocation()
        FOVCircle.Position = m
        FOVCircle.Radius = AimlockFOV
        FOVCircle.Visible = AimlockEnabled
    end

    if not AimlockEnabled then return end

    local cam = workspace.CurrentCamera
    local mouse = game.Players.LocalPlayer:GetMouse()
    local closest, minDist = nil, AimlockFOV

    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= game.Players.LocalPlayer and p.Character and p.Character:FindFirstChild("Head") then
            local pos, vis = cam:WorldToViewportPoint(p.Character.Head.Position)
            if vis then
                local d = (Vector2.new(pos.X, pos.Y) - Vector2.new(mouse.X, mouse.Y)).Magnitude
                if d < minDist then
                    minDist = d
                    closest = p
                end
            end
        end
    end

    if closest and closest.Character and closest.Character.Head then
        local target = closest.Character.Head.Position
        cam.CFrame = cam.CFrame:Lerp(CFrame.new(cam.CFrame.Position, target), 1/AimlockSmooth)
    end
end)

game:GetService("UserInputService").InputBegan:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton2 then AimlockEnabled = true end
end)
game:GetService("UserInputService").InputEnded:Connect(function(i)
    if i.UserInputType == Enum.UserInputType.MouseButton2 then AimlockEnabled = false end
end)

