-- ==================== VARIABLES ====================
local ESPEnabled = false
local ESPObjects = {}
local AimlockEnabled = false
local AimlockFOV = 120
local AimlockSmooth = 8
local FOVCircle

-- ==================== STRONG ESP (Naprawiony + Rozbudowany) ====================
local function UpdateAllESP()
    if not ESPEnabled then return end
    
    for _, player in pairs(game.Players:GetPlayers()) do
        if player == game.Players.LocalPlayer then continue end
        
        local character = player.Character
        if not character then 
            if ESPObjects[player] then
                for _, obj in pairs(ESPObjects[player]) do obj:Remove() end
                ESPObjects[player] = nil
            end
            continue 
        end
        
        local root = character:FindFirstChild("HumanoidRootPart")
        local head = character:FindFirstChild("Head")
        local humanoid = character:FindFirstChild("Humanoid")
        
        if not root or not head or not humanoid then continue end
        
        if not ESPObjects[player] then
            ESPObjects[player] = {}
        end
        
        local rootPos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(root.Position)
        if not onScreen then continue end
        
        local headPos = workspace.CurrentCamera:WorldToViewportPoint(head.Position)
        local legPos = workspace.CurrentCamera:WorldToViewportPoint(root.Position - Vector3.new(0, 3, 0))
        
        local height = math.abs(headPos.Y - legPos.Y)
        local width = height * 0.6
        
        -- Box
        local box = ESPObjects[player].Box or Drawing.new("Square")
        box.Thickness = 2
        box.Color = Color3.fromRGB(255, 50, 50)
        box.Transparency = 1
        box.Filled = false
        box.Size = Vector2.new(width, height)
        box.Position = Vector2.new(rootPos.X - width/2, rootPos.Y - height/2)
        ESPObjects[player].Box = box
        
        -- Name
        local name = ESPObjects[player].Name or Drawing.new("Text")
        name.Text = player.Name
        name.Size = 15
        name.Color = Color3.fromRGB(255, 255, 255)
        name.Outline = true
        name.Center = true
        name.Position = Vector2.new(rootPos.X, rootPos.Y - height/2 - 20)
        ESPObjects[player].Name = name
        
        -- Distance
        local distance = (game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart") and 
                         (root.Position - game.Players.LocalPlayer.Character.HumanoidRootPart.Position).Magnitude) or 0
        
        local distText = ESPObjects[player].Dist or Drawing.new("Text")
        distText.Text = string.format("%.0f studs", distance)
        distText.Size = 14
        distText.Color = Color3.fromRGB(200, 200, 200)
        distText.Outline = true
        distText.Center = true
        distText.Position = Vector2.new(rootPos.X, rootPos.Y + height/2 + 5)
        ESPObjects[player].Dist = distText
        
        -- Health Bar
        if humanoid.Health then
            local healthBar = ESPObjects[player].Health or Drawing.new("Square")
            local healthPercent = humanoid.Health / humanoid.MaxHealth
            healthBar.Size = Vector2.new(4, height * healthPercent)
            healthBar.Position = Vector2.new(rootPos.X - width/2 - 8, rootPos.Y - height/2 + (height * (1 - healthPercent)))
            healthBar.Color = Color3.fromRGB(255 - (255 * healthPercent), 255 * healthPercent, 0)
            healthBar.Thickness = 1
            healthBar.Filled = true
            ESPObjects[player].Health = healthBar
        end
    end
end

-- ESP Toggle
BloxStrikeTab:CreateToggle({
    Name = "ESP Players (Box + Name + Distance + Health)",
    CurrentValue = false,
    Flag = "StrongESP",
    Callback = function(Value)
        ESPEnabled = Value
        
        if Value then
            game:GetService("RunService").RenderStepped:Connect(UpdateAllESP)
