-- ==================== CONFIG ====================
local ESP = {
    Enabled = false,
    ShowBox = true,
    ShowName = true,
    ShowDistance = true,
    ShowHealth = true,
    BoxColor = Color3.fromRGB(255, 50, 50),
    TextColor = Color3.fromRGB(255, 255, 255),
    Objects = {}
}

local HitboxEnabled = false
local HitboxSize = 2.5
local HitboxTransparency = 0.7

local AimlockEnabled = false
local AimlockFOV = 120
local AimlockSmooth = 8
local FOVCircle = nil

-- ==================== ESP FUNCTIONS ====================
local function DestroyESP(player)
    if ESP.Objects[player] then
        for _, v in pairs(ESP.Objects[player]) do
            pcall(function() v:Remove() end)
        end
        ESP.Objects[player] = nil
    end
end

local ESPConnection

local function StartESP()
    if ESPConnection then ESPConnection:Disconnect() end
    ESPConnection = game:GetService("RunService").RenderStepped:Connect(function()
        if not ESP.Enabled then return end

        for _, player in pairs(game.Players:GetPlayers()) do
            if player == game.Players.LocalPlayer then continue end

            local char = player.Character
            if not char then DestroyESP(player); continue end

            local root = char:FindFirstChild("HumanoidRootPart")
            local head = char:FindFirstChild("Head")
            local hum = char:FindFirstChild("Humanoid")
            if not root or not head or not hum then DestroyESP(player); continue end

            local rootPos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(root.Position)
            if not onScreen then DestroyESP(player); continue end

            local headPos = workspace.CurrentCamera:WorldToViewportPoint(head.Position)
            local legPos = workspace.CurrentCamera:WorldToViewportPoint(root.Position - Vector3.new(0, 3.5, 0))
            local height = math.abs(headPos.Y - legPos.Y)
            local width = height * 0.65

            if not ESP.Objects[player] then ESP.Objects[player] = {} end

            -- Box
            if ESP.ShowBox then
                local box = ESP.Objects[player].Box or Drawing.new("Square")
                box.Thickness = 2
                box.Color = ESP.BoxColor
                box.Transparency = 1
                box.Filled = false
                box.Size = Vector2.new(width, height)
                box.Position = Vector2.new(rootPos.X - width/2, rootPos.Y - height/2)
                ESP.Objects[player].Box = box
            end

            -- Name
            if ESP.ShowName then
                local name = ESP.Objects[player].Name or Drawing.new("Text")
                name.Text = player.Name
                name.Size = 15
                name.Color = ESP.TextColor
                name.Outline = true
                name.Center = true
                name.Position = Vector2.new(rootPos.X, rootPos.Y - height/2 - 22)
                ESP.Objects[player].Name = name
            end

            -- Distance
            if ESP.ShowDistance then
                local dist = (root.Position - (game.Players.LocalPlayer.Character and game.Players.LocalPlayer.Character:FindFirstChild("HumanoidRootPart") or root).Position).Magnitude
                local dtext = ESP.Objects[player].Dist or Drawing.new("Text")
                dtext.Text = string.format("%.0f stud", dist)
                dtext.Size = 14
                dtext.Color = Color3.fromRGB(200,200,200)
                dtext.Outline = true
                dtext.Center = true
                dtext.Position = Vector2.new(rootPos.X, rootPos.Y + height/2 + 8)
                ESP.Objects[player].Dist = dtext
            end

            -- Health
            if ESP.ShowHealth then
                local hp = ESP.Objects[player].Health or Drawing.new("Square")
                local percent = hum.Health / hum.MaxHealth
                hp.Size = Vector2.new(4, height * percent)
                hp.Position = Vector2.new(rootPos.X - width/2 - 8, rootPos.Y - height/2 + height*(1-percent))
                hp.Color = Color3.fromRGB(255*(1-percent), 255*percent, 0)
                hp.Filled = true
                ESP.Objects[player].Health = hp
            end
        end
    end)
end

-- ==================== UI ====================
BloxStrikeTab:CreateToggle({
